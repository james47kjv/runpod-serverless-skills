# <APP> — vLLM-based serverless runtime.
#
# Contract:
#   - Base is vLLM's official OpenAI-server image (0.19.1, CUDA 13, Ubuntu 24.04).
#     We picked this over SGLang because SGLang v0.5.10.post1 has no
#     CLI-exposed FP4 GEMM backend override, and its default flashinfer_cudnn
#     FP4 path fails cudnn_frontend.check_support for Qwen3.5 NVFP4 MoE on
#     Blackwell.
#   - vLLM has first-class Qwen3.5 MoE + compressed-tensors W4A4 NVFP4 support
#     (NVIDIA ships nvidia/Qwen3.5-397B-A17B-NVFP4 as the reference model).
#   - Model weights are NOT baked into this image. RunPod's managed HF cache
#     (triggered by the spec's `modelName` + `flashboot: true`) places the
#     pinned snapshot on each worker. start.sh resolves that path for vLLM.

FROM vllm/vllm-openai:v0.19.1-cu130-ubuntu2404

# CRITICAL: vLLM's image (and TEI/TGI/NIM/Whisper bases) sets ENTRYPOINT to
# its model-server. The OCI spec says `ENTRYPOINT []` clears the inherited
# entrypoint, but RunPod's container runtime does NOT honor that reliably —
# it preserves the inherited ENTRYPOINT and passes our CMD/dockerStartCmd as
# args, causing `vllm-server bash /app/services/<APP>/start.sh` to run, dying
# in milliseconds with "exit code 1" and ZERO Container logs because start.sh
# never ran. Explicit ENTRYPOINT is the only robust pattern across runtimes.
# See pitfalls-34.md #27 and setup-guide §6.1.4 for the full breakdown.
ENTRYPOINT ["bash", "/app/services/<APP>/start.sh"]

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    <APP>_MODE=BENCHMARK_SAFE \
    <APP>_PROMPT_INJECT_HINTS=0 \
    <APP>_GRAPHITI_READS=1 \
    <APP>_GRAPHITI_WRITES=0 \
    <APP>_BASE=/app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl git && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Application deps on top of vLLM runtime. vLLM's base image already has
# fastapi / uvicorn / pydantic / requests. We just add our specifics.
COPY services/<APP>/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir \
    "sec-api>=1.0.30" \
    "tenacity>=9.0" \
    "python-dotenv>=1.0" \
    "huggingface_hub>=0.24"

# --- Harness payload -------------------------------------------------------
COPY adapters/               /app/adapters/
COPY extractors/             /app/extractors/
COPY <evidence_package>/ /app/<evidence_package>/
COPY <evidence-package>/ /app/<evidence-package>/
COPY config/                 /app/config/
COPY benchmark_data/         /app/benchmark_data/
COPY benchmark_data_paths.py       /app/
COPY finance_router.py             /app/
COPY contract_validator.py         /app/
COPY metasystem_harness.py         /app/
COPY programmatic_engine.py        /app/
COPY direct_answer_constructor.py  /app/
COPY v4_integration.py             /app/
COPY services/__init__.py                   /app/services/__init__.py
COPY services/finance_endpoint/__init__.py  /app/services/finance_endpoint/__init__.py
COPY services/<APP>/app.py            /app/services/<APP>/app.py
COPY services/<APP>/agent_runtime.py  /app/services/<APP>/agent_runtime.py
COPY services/<APP>/start.sh          /app/services/<APP>/start.sh
RUN chmod +x /app/services/<APP>/start.sh

# Build-context audit artifact
RUN python3 -c "import hashlib, json, pathlib; \
root = pathlib.Path('/app'); \
entries = []; \
[entries.append({'path': str(p.relative_to(root)), 'sha256': hashlib.sha256(p.read_bytes()).hexdigest(), 'size': p.stat().st_size}) \
 for p in sorted(root.rglob('*')) if p.is_file() and '__pycache__' not in p.parts and not p.name.endswith('.pyc')]; \
open('/app/BUILD_MANIFEST.json', 'w').write(json.dumps({'entries': entries}, indent=2))"

EXPOSE 8080
# CMD intentionally empty — ENTRYPOINT handles invocation, and the spec's
# `dockerStartCmd: ["bash", "/app/services/<APP>/start.sh"]` is the second
# (defense-in-depth) layer. Setting CMD to the script too would be redundant
# and could confuse runtimes that interpret CMD as entrypoint args.
CMD []
