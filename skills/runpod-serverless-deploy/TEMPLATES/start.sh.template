#!/usr/bin/env bash
# <APP> — vLLM-based endpoint boot.
#
# Contract:
#   - Required env: <APP>_HF_MODEL_REPO, <APP>_HF_MODEL_REVISION.
#   - Resolves the model path from RunPod's FlashBoot-populated HF cache;
#     falls back to HF download via HF_TOKEN only if the cache is missing.
#   - Launches vLLM's OpenAI server on port 30000, FastAPI harness on
#     port 8080. FastAPI's model client talks to vLLM on 127.0.0.1:30000/v1.
#   - No silent failures: every boot stage emits structured JSON; every
#     process exit (including status=0) is treated as a boot failure.

# CRITICAL ORDERING: emit start_sh_entered BEFORE `set -euo pipefail`.
# This is the canary echo that proves start.sh actually ran. If the script
# aborts on any subsequent line, this echo has already flushed to stdout
# and is visible in Container logs — telling you "the script ran but failed
# at line N", not "the script never ran". If you ever see "exit code 1"
# without this line in Container logs, the failure is upstream of start.sh:
# almost always a Dockerfile `ENTRYPOINT []` hijack (pitfall #27, fix:
# explicit `ENTRYPOINT ["bash", "/app/start.sh"]`) or a missing
# `dockerStartCmd` in the spec (pitfall #26).
# `whoami`/`uid` fields tell you the runtime user — TEI/TGI/some NVIDIA
# bases run as non-root, which makes /root/.cache/* mkdirs fail silently.
echo '{"event":"start_sh_entered","ts":"'"$(date -u +%FT%TZ)"'","whoami":"'"$(id -un 2>/dev/null || echo unknown)"'","uid":"'"$(id -u 2>/dev/null || echo unknown)"'"}'

# Anchor HF cache at /tmp (always world-writable). TEI/TGI and several
# inference base images run as a non-root user; mkdir -p /root/.cache/...
# fails with `Permission denied`, and under `set -e` the script aborts
# silently (echoes after the failed mkdir never run). FlashBoot keeps the
# warm copy on the HOST regardless of in-container path, so anchoring at
# /tmp doesn't lose the cache benefit.
# IMPORTANT — two-tier HF cache pattern (LAMP1 plugin reference, proven working).
# READ from RunPod's host-cached models when present (FlashBoot win path).
# /runpod-volume/huggingface-cache/hub is host-local, populated by spec.modelName
# — NOT a user-attached Network Volume; does NOT pin region. Anchoring the
# cache at /tmp instead defeats FlashBoot — every scale-from-zero re-downloads
# the model (3-5 min for 7-8 GB). Spec env MUST NOT hard-code HF_HOME or
# HUGGINGFACE_HUB_CACHE — let this runtime detection decide.
# See pitfall #30 / setup-guide section 6.1.7.
#
# CRITICAL — use UNCONDITIONAL assignment (NOT bash `:=`).
# TEI/TGI/vLLM/NIM/Whisper base images all preset HUGGINGFACE_HUB_CACHE=/data
# (and similar for HF_HOME) in the image's ENV layer. Bash `:=` is a NO-OP
# when the var is already set to a non-empty value, so `: "${X:=y}"` would
# silently leave the base-image's `/data` in place — the model loader then
# reads from /data (which doesn't exist on serverless), gets ENOENT, and
# hangs forever on "Loading model" with no error. The diagnostic LIES:
# the hf_cache_resolved log says `runpod-host` but `printenv` inside the
# container shows `/data`. Always assign unconditionally.
# See pitfall #31 / setup-guide section 6.1.8.
RUNPOD_HUB_CACHE="/runpod-volume/huggingface-cache/hub"
if [[ -d "$RUNPOD_HUB_CACHE" ]] && touch "$RUNPOD_HUB_CACHE/.write-probe" 2>/dev/null && rm -f "$RUNPOD_HUB_CACHE/.write-probe" 2>/dev/null; then
    HUGGINGFACE_HUB_CACHE="$RUNPOD_HUB_CACHE"
    CACHE_LOCATION="runpod-host"
elif [[ -d "$RUNPOD_HUB_CACHE" ]]; then
    HUGGINGFACE_HUB_CACHE="/tmp/<APP>-hf-cache"
    CACHE_LOCATION="runpod-host-readonly-fallback-to-tmp"
else
    HUGGINGFACE_HUB_CACHE="/tmp/<APP>-hf-cache"
    CACHE_LOCATION="tmp-fallback"
fi
# WRITE — keep HF_HOME on /tmp so any tokens/non-cache state is always writable.
# Unconditional assignment (NOT `:=`) for the same reason as HUGGINGFACE_HUB_CACHE.
HF_HOME="/tmp/<APP>-hf-home"
mkdir -p /tmp/<APP>-hf-cache /tmp/<APP>-hf-home || {
    echo '{"event":"tmp_mkdir_failed","whoami":"'"$(id -un 2>/dev/null)"'"}' >&2
    exit 1
}
mkdir -p "$HUGGINGFACE_HUB_CACHE" 2>/dev/null || true
export HUGGINGFACE_HUB_CACHE HF_HOME
echo '{"event":"hf_cache_resolved","location":"'"$CACHE_LOCATION"'","hub_cache":"'"$HUGGINGFACE_HUB_CACHE"'","hf_home":"'"$HF_HOME"'"}'

# Newer huggingface_hub honors HF_TOKEN, but older TEI/TGI builds look
# exclusively at HUGGING_FACE_HUB_TOKEN for private-repo auth. Mirror
# the value if only one is set so private models always download.
export HUGGING_FACE_HUB_TOKEN="${HUGGING_FACE_HUB_TOKEN:-${HF_TOKEN:-}}"
export HF_TOKEN="${HF_TOKEN:-${HUGGING_FACE_HUB_TOKEN:-}}"

# set -e enabled AFTER the canary echoes so any failure from this point
# flushes its own diagnostic before the script aborts.
set -euo pipefail

log() {
    printf '{"ts":"%s","level":"%s","stage":"boot","event":"%s","msg":%s}\n' \
        "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$1" "$2" \
        "$(printf '%s' "$3" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read().strip()))')" >&2
}

die() { log ERROR "$1" "$2"; exit 1; }

<APP>_HF_MODEL_REPO="${<APP>_HF_MODEL_REPO:-}"
<APP>_HF_MODEL_REVISION="${<APP>_HF_MODEL_REVISION:-}"
[[ -z "${<APP>_HF_MODEL_REPO}" ]] && die missing_model_repo "<APP>_HF_MODEL_REPO must be set by the endpoint spec"
[[ -z "${<APP>_HF_MODEL_REVISION}" ]] && die missing_model_revision "<APP>_HF_MODEL_REVISION must be set (pin revision)"

RUNPOD_HF_CACHE_ROOT="${<APP>_RUNPOD_HF_CACHE_ROOT:-/runpod-volume/huggingface-cache/hub}"
REPO_CACHE_DIR="models--${<APP>_HF_MODEL_REPO//\//--}"
SNAPSHOT_PATH="${RUNPOD_HF_CACHE_ROOT}/${REPO_CACHE_DIR}/snapshots/${<APP>_HF_MODEL_REVISION}"

if [[ -d "${SNAPSHOT_PATH}" ]]; then
    log INFO model_cache_hit "FlashBoot cache hit at ${SNAPSHOT_PATH}"
    MODEL_PATH="${SNAPSHOT_PATH}"
else
    log WARN model_cache_miss "FlashBoot cache miss at ${SNAPSHOT_PATH}; attempting HF download"
    [[ -z "${HF_TOKEN:-}" ]] && die model_unavailable "FlashBoot cache missing AND HF_TOKEN unset; cannot self-heal"
    MODEL_PATH="$(
        <APP>_HF_MODEL_REPO="${<APP>_HF_MODEL_REPO}" \
        <APP>_HF_MODEL_REVISION="${<APP>_HF_MODEL_REVISION}" \
        <APP>_HF_CACHE_DIR="${<APP>_HF_CACHE_DIR:-${RUNPOD_HF_CACHE_ROOT%/hub}}" \
        python3 - <<'PY'
import os
from huggingface_hub import snapshot_download

kwargs = {
    "repo_id": os.environ["<APP>_HF_MODEL_REPO"],
    "revision": os.environ["<APP>_HF_MODEL_REVISION"],
    "token": os.environ.get("HF_TOKEN") or None,
}
cache = os.environ.get("<APP>_HF_CACHE_DIR")
if cache:
    kwargs["cache_dir"] = cache
print(snapshot_download(local_files_only=False, **kwargs))
PY
    )"
    [[ -z "${MODEL_PATH}" || ! -d "${MODEL_PATH}" ]] && die model_download_failed "snapshot_download produced no usable path"
    log INFO model_downloaded "Model resolved to ${MODEL_PATH}"
fi

export <APP>_MODEL_PATH="${MODEL_PATH}"

VLLM_PORT="${<APP>_VLLM_PORT:-30000}"
API_PORT="${PORT:-${<APP>_API_PORT:-8080}}"
# RunPod's LB health-poller looks at $PORT_HEALTH (NOT $PORT) to find /ping.
# Bind FastAPI's /ping route to this port. If unset, fall back to API_PORT and
# emit a structured WARNING — the deploy-side guard (deploy_endpoint.py
# _require_port_health) is the primary defense, this log line is the
# diagnostic-of-last-resort. See pitfalls-35.md #25 / setup-guide §6.1.2.
HEALTH_PORT="${PORT_HEALTH:-}"
if [[ -z "${HEALTH_PORT}" ]]; then
    log WARN port_health_unset "PORT_HEALTH is unset — RunPod's LB poller will not find /ping; falling back to ${API_PORT} so the in-container app still works"
    HEALTH_PORT="${API_PORT}"
fi
export HEALTH_PORT
READY_FILE="${<APP>_READY_FILE:-/tmp/<APP>.ready}"
rm -f "${READY_FILE}"
export <APP>_READY_FILE="${READY_FILE}"
export <APP>_WORKSPACE_ROOT="${<APP>_WORKSPACE_ROOT:-/tmp/lamp-workspaces}"
mkdir -p "${<APP>_WORKSPACE_ROOT}"

# vLLM OpenAI server runs on :30000. FastAPI harness talks to it.
export <APP>_MODEL_BASE_URL="${<APP>_MODEL_BASE_URL:-http://127.0.0.1:${VLLM_PORT}/v1}"
export <APP>_PUBLIC_MODEL_NAME="${<APP>_PUBLIC_MODEL_NAME:-<GHCR_OWNER>/<APP>}"

# vLLM-served model name (internal, what vLLM exposes on its /v1/models).
VLLM_SERVED_NAME="${<APP>_VLLM_SERVED_NAME:-<APP>}"

cleanup() {
    if [[ -n "${API_PID:-}" ]] && kill -0 "${API_PID}" 2>/dev/null; then
        kill "${API_PID}" 2>/dev/null || true
    fi
    if [[ -n "${VLLM_PID:-}" ]] && kill -0 "${VLLM_PID}" 2>/dev/null; then
        kill "${VLLM_PID}" 2>/dev/null || true
    fi
}
trap cleanup EXIT INT TERM

log INFO launching_api "FastAPI on :${API_PORT}"
cd /app
python3 -m uvicorn services.finance_endpoint:app \
    --host 0.0.0.0 --port "${API_PORT}" --workers 1 \
    > /tmp/uvicorn.log 2>&1 &
API_PID=$!

# Launch vLLM OpenAI server.
#   --enable-prefix-caching: standard Qwen3.5 NVFP4 recipe.
#   --reasoning-parser qwen3: per vLLM Qwen3.5 recipe.
#   --gpu-memory-utilization 0.85: matches the SGLang mem-fraction we used.
#   --max-model-len 32768: Vals questions fit comfortably in 32k; full 262k
#     context blows up KV memory and is unnecessary.
#   --trust-remote-code: for Qwen3.5 custom modeling.
#   <APP>_VLLM_EXTRA_ARGS: escape hatch for per-deploy tuning.
log INFO launching_vllm "vLLM on :${VLLM_PORT} serving ${MODEL_PATH}"
python3 -m vllm.entrypoints.openai.api_server \
    --model "${MODEL_PATH}" \
    --served-model-name "${VLLM_SERVED_NAME}" \
    --host 0.0.0.0 --port "${VLLM_PORT}" \
    --trust-remote-code \
    --enable-prefix-caching \
    --reasoning-parser qwen3 \
    --max-model-len 32768 \
    --gpu-memory-utilization 0.85 \
    ${<APP>_VLLM_EXTRA_ARGS:-} \
    > /tmp/vllm.log 2>&1 &
VLLM_PID=$!

log INFO waiting_vllm "waiting for vLLM /health"
READY=0
for i in $(seq 1 360); do
    if ! kill -0 "${API_PID}" 2>/dev/null; then
        log ERROR api_exit_before_ready "FastAPI exited before vLLM ready (after ${i}s)"
        tail -n 200 /tmp/uvicorn.log >&2 || true
        exit 1
    fi
    if ! kill -0 "${VLLM_PID}" 2>/dev/null; then
        log ERROR vllm_exit_before_ready "vLLM exited before ready (after ${i}s)"
        tail -n 200 /tmp/vllm.log >&2 || true
        exit 1
    fi
    if curl -sf "http://127.0.0.1:${VLLM_PORT}/health" > /dev/null; then
        READY=1
        log INFO vllm_ready "vLLM ready after ${i}s"
        break
    fi
    sleep 5
done

[[ "${READY}" != "1" ]] && { log ERROR vllm_never_ready "vLLM /health never succeeded in 1800s"; tail -n 200 /tmp/vllm.log >&2 || true; exit 1; }

mkdir -p "$(dirname "${READY_FILE}")"
touch "${READY_FILE}"
log INFO runtime_ready "Ready file written; accepting traffic"

STATUS=0
EXITED_PID=""
if ! wait -n -p EXITED_PID "${VLLM_PID}" "${API_PID}"; then
    STATUS=$?
fi

EXITED_NAME="child"
EXITED_LOG=""
if [[ "${EXITED_PID:-}" == "${API_PID}" ]]; then
    EXITED_NAME="FastAPI"; EXITED_LOG="/tmp/uvicorn.log"
elif [[ "${EXITED_PID:-}" == "${VLLM_PID}" ]]; then
    EXITED_NAME="vLLM"; EXITED_LOG="/tmp/vllm.log"
fi

log ERROR child_exit "${EXITED_NAME} exited with status ${STATUS}"
[[ "${STATUS}" == "0" ]] && { log ERROR unexpected_clean_exit "Treating unexpected ${EXITED_NAME} exit(0) as failure"; STATUS=1; }
[[ -n "${EXITED_LOG}" ]] && tail -n 200 "${EXITED_LOG}" >&2 || true

cleanup
exit "${STATUS}"
