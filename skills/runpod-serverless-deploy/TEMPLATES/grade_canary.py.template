#!/usr/bin/env python3
"""Grade a canary report against the public.csv expected answers.

Uses simple lexical overlap + failure-marker detection. Not as strict as Vals'
judge LLM, but good enough to distinguish 'roughly correct' from 'fail-closed'.
"""
from __future__ import annotations

import csv
import json
import pathlib
import re
import sys

REPO_ROOT = pathlib.Path(__file__).resolve().parents[2]
PUBLIC_CSV = REPO_ROOT / "benchmark_data" / "data" / "public.csv"

FAIL_MARKERS = [
    "no information available",
    "data unavailable",
    "programmatic_extraction_failed",
    "no compliant",
    "no evidence",
    "cannot provide",
]


def _load_expected(limit: int) -> list[dict]:
    rows = []
    with PUBLIC_CSV.open(encoding="utf-8", newline="") as fh:
        for idx, row in enumerate(csv.DictReader(fh), start=1):
            rows.append({
                "q_num": idx,
                "question": (row.get("Question") or "").strip(),
                "expected": (row.get("Answer") or "").strip(),
                "family": (row.get("Question Type") or "").strip(),
            })
            if len(rows) >= limit:
                break
    return rows


def _token_overlap(a: str, b: str) -> float:
    a_tokens = set(re.findall(r"[A-Za-z0-9.]+", a.lower()))
    b_tokens = set(re.findall(r"[A-Za-z0-9.]+", b.lower()))
    if not b_tokens:
        return 0.0
    return len(a_tokens & b_tokens) / len(b_tokens)


def _numeric_tokens(text: str) -> set[str]:
    return set(re.findall(r"\d[\d,\.]*", text))


def grade_one(expected: str, answer: str) -> dict:
    answer_lower = answer.lower()
    fail_hit = next((m for m in FAIL_MARKERS if m in answer_lower), None)

    overlap = _token_overlap(answer, expected)
    num_exp = _numeric_tokens(expected)
    num_got = _numeric_tokens(answer)
    num_overlap = len(num_got & num_exp) / max(1, len(num_exp))

    status = "pass"
    reason = ""
    if not answer.strip():
        status = "empty"; reason = "empty answer"
    elif fail_hit:
        status = "fail_closed"; reason = f"marker: {fail_hit!r}"
    elif overlap < 0.1:
        status = "drift"; reason = f"token_overlap={overlap:.2f} too low"
    elif num_exp and num_overlap < 0.3:
        status = "num_drift"; reason = f"numeric_overlap={num_overlap:.2f}/{len(num_exp)} nums"

    return {
        "status": status,
        "reason": reason,
        "token_overlap": round(overlap, 3),
        "numeric_overlap": round(num_overlap, 3) if num_exp else None,
        "expected_preview": expected[:120],
        "answer_preview": answer[:200],
    }


def main() -> int:
    import argparse
    ap = argparse.ArgumentParser(description=__doc__)
    ap.add_argument("--report-dir", required=True)
    ap.add_argument("--limit", type=int, default=50)
    ap.add_argument("--out", default="")
    args = ap.parse_args()

    expected = _load_expected(args.limit)
    report_dir = pathlib.Path(args.report_dir)
    per_q = []
    summary = {"pass": 0, "drift": 0, "num_drift": 0, "fail_closed": 0, "empty": 0, "missing": 0}

    for exp in expected:
        q_file = report_dir / f"q{exp['q_num']:03d}.json"
        if not q_file.exists():
            summary["missing"] += 1
            per_q.append({"q_num": exp["q_num"], "status": "missing", "family": exp["family"]})
            continue
        raw = json.loads(q_file.read_text(encoding="utf-8"))
        answer = (raw.get("answer") or "").strip()
        grade = grade_one(exp["expected"], answer)
        grade["q_num"] = exp["q_num"]
        grade["family"] = exp["family"]
        grade["latency_ms"] = raw.get("latency_ms")
        summary[grade["status"]] = summary.get(grade["status"], 0) + 1
        per_q.append(grade)

    total = len(expected)
    out_payload = {
        "total": total,
        "pass_rate": summary["pass"] / total if total else 0.0,
        "summary": summary,
        "per_question": per_q,
    }
    print(json.dumps(out_payload, indent=2))
    if args.out:
        pathlib.Path(args.out).write_text(json.dumps(out_payload, indent=2), encoding="utf-8")
    return 0 if summary["pass"] == total else 1


if __name__ == "__main__":
    sys.exit(main())
